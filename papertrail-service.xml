<service>
  <id>Papertrail</id>
  <name>Papertrail Document Service</name>
  <description>Papertrail Document Generator Node.js Service</description>
  <executable>node</executable>
  <arguments>server.js</arguments>
  <workingdirectory>C:\document-generator-pnm\backend</workingdirectory>
  <logpath>C:\document-generator-pnm\backend\logs</logpath>
  <log mode="roll-by-size">
    <sizeThreshold>10240</sizeThreshold>
    <keepFiles>5</keepFiles>
  </log>
  <onfailure action="restart" delay="3 sec"/>
  <onfailure action="restart" delay="10 sec"/>
</service>